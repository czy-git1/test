/**app.wxss**/
.container {
  height: 100%;
  padding: 5px 2%;
  box-sizing: border-box;
} 
.auth-pop{
  padding: 10px 4%;
  position: relative;
}
.auth-pop .auth-head{
  padding: 5px 0;
  font-size: 14px;
}
.auth-pop .auth-bold{
  font-size: 16px;
  padding: 10px 0;
}
.auth-pop .auth-btns{
  text-align: center;
  margin-top: 10%;
}
.auth-btns van-button{
  margin: 0 5%;
}
.auth-btn{
  padding: 0 30px !important;
  font-weight: bold;
}
.add-button{
  width: 60px;
  height: 60px;
  border-radius: 30px;
  position: fixed;
  right: 4%;
  bottom: 50px;
  background-color: #2e75b6;
  color: #fff;
  font-size: smaller;
  text-align: center;
  box-shadow: 2px 2px 5px #ccc;
}
.add-button .add-icon{
  font-size: 28px;
  margin-bottom: -5px;
}
.no-more{
  color: #aaa;
  font-size: small;
  text-align: center;
  padding: 5px 0;
}