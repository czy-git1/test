<!--pages/user/profile.wxml-->
<view class="content">
  <view class="profile">
    <view class="item">
      <image class="icon-l profile-img" src="{{userInfo.pic==null?'http://129.211.222.131:18080/images/20230309132054typ1q.jpg':userInfo.pic}}"></image>
      
      <view class="nickname">
      {{userInfo.nickName}}
      </view>
      <!-- <view class="count">
        <text wx:if="{{userInfo.city!=null}}">{{userInfo.city}}</text>
        <text wx:if="{{userInfo.city==null}}">未知地区</text>
      </view> -->
      <!-- <view class="count">
        <text wx:if="{{userInfo.shortDesc==null}}">无个人简介</text>
        <text wx:else>{{userInfo.shortDesc}}</text>
      </view> -->
    </view>
  </view>
  <view class="profile">
    <van-cell value="" icon="location" is-link link-type="navigateTo" url="/pages/user/address">
      <view slot="title"><view class="van-cell-text">地址管理</view></view>
    </van-cell>
    <van-cell value="" icon="completed" is-link link-type="navigateTo" url="/pages/order/myorders">
      <view slot="title"><view class="van-cell-text">我的订单</view></view>
    </van-cell>
    <van-cell value="" icon="star" is-link link-type="navigateTo" url="/pages/user/myproduct/myproduct">
      <view slot="title"><view class="van-cell-text">我收藏的商品</view></view>
    </van-cell>
    <van-cell icon="todo-list" is-link link-type="navigateTo" url="/pages/user/info">
      <view slot="title"><view class="van-cell-text">修改个人信息</view></view>
    </van-cell>
    <van-cell icon="clear" is-link bindtap="onLogout">
      <view slot="title"><view class="van-cell-text">退出登录</view></view>
    </van-cell>
    <!-- <van-cell value="" icon="comment" is-link link-type="navigateTo" url="/pages/message/msg-list">
      <view slot="title"><view class="van-cell-text">消息通知</view></view>
    </van-cell> -->
  </view>

  <!-- <view class="logout-btn" wx:if="{{!notLogin}}">
    <van-button color="#2e75b6" icon="edit" bind:click="toEditPage">修改信息</van-button>
    <van-button color="#b55a4b" icon="close" bind:click="onLogout">退出登录</van-button>
  </view> -->
</view>
