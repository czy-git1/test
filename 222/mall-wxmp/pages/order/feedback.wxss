/* pages/capsule/capsule-publish.wxss *//* miniprogram/pages/select_role/role.wxss */
.select-view{
  margin-top: 40%;
}
.user-file{
  font-size: 14px;
  padding: 0 2%;
}
.val-input{
  margin-bottom: 10px;
}
.val-input .label .desc{
  font-weight: normal;
  font-size: 14px;
  color: #999;
  padding-left: 10px;
}
.user-file .label{
  color: #666;
  padding: 8px 0;
  font-weight: bold;
}
.user-file input, .user-file textarea, .picker{
  width: 100%;
  box-sizing: border-box;
  padding: 5px 2%;
  border: 1px solid #2e75b6;
}
.category-txt{
  color: #2e75b6;
  font-size: 18px;
}
.user-file textarea{height: 150px;}
.user-file input{height: 35px;}
.user-file .orange-btn{
  margin-top: 15px;
}
.bottom-btn{
  margin-bottom: 20px;
  text-align: center;
}
.fb-btn{
  display: inline-block;
  height: 35px;
  line-height: 35px;
  background: #2e75b6;
  color: #fff;
  width: 120px;
  text-align: center;
  border-radius: 17px;
}
.img-list{
  display: flex;
  flex-wrap: wrap;
  /* justify-content: space-between; */
  padding: 10px 0;
}
.upload-img{
  width: 31%;
  height: 90px;
  text-align: center;
  margin-bottom: 10px;
  position: relative;
  padding: 0 1%;
}
.upload-img .pic{
  width: 100%;
  height: 90px;
}
.camera-icon{
  width:80px;
  height:80px;
}
.upload-img .del-btn{
  position: absolute;
  right: 2px;
  top: 2px;
  width: 20px;
  height: 20px;
  padding: 4px;
}
.input-btn-lin{
  position: relative;
}
.form-type{
  font-size: large;
  margin: 12px 0;
  color: #2e75b6;
  text-align: center;
}
.pn{
  color: #2e75b6;
}